# ──────────────────────────────────────────────────────────────
# yasirbashir.com — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, never committed.
# ──────────────────────────────────────────────────────────────

# ── Supabase (Project Settings → API) ─────────────────────────
# Project URL — public, safe to expose
VITE_SUPABASE_URL=

# Publishable (anon) key — public, safe to expose
# New format: sb_publishable_…
VITE_SUPABASE_PUBLISHABLE_KEY=

# Secret (service_role) key — SERVER ONLY, never expose to browser
# New format: sb_secret_…
SUPABASE_SECRET_KEY=

# Database password — only used by Supabase CLI for migrations
SUPABASE_DB_PASSWORD=

# ── Vercel ────────────────────────────────────────────────────
# Deploy hook URL — triggers a rebuild when CMS content publishes
VERCEL_DEPLOY_HOOK_URL=
